# =============================================================================
# QR369-GCP — Variáveis de Ambiente (Referência)
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env!
# =============================================================================

# ── virtual-assistant ─────────────────────────────────────────────────────────

# Perfil Spring ativo: anthropic | ollama
SPRING_PROFILES_ACTIVE=anthropic

# Chave da API Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# URL base do servidor Ollama (usado para embeddings e perfil ollama)
SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434

# PostgreSQL / pgvector
VA_DB_URL=jdbc:postgresql://localhost:5432/ragdb
VA_DB_USERNAME=postgres
VA_DB_PASSWORD=CHANGE_ME

# Redis
VA_REDIS_HOST=localhost
VA_REDIS_PORT=6379

# ── prospecting-service ───────────────────────────────────────────────────────

# Porta do servidor (padrão 8081)
PS_SERVER_PORT=8081
